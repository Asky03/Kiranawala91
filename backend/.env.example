# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://kiranawala_user:kiranawala_dev_2026@localhost:5432/kiranawala_dev

# ─── JWT (used Day 2) ────────────────────────────────────
# Generate a secure random string: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret-string-at-least-64-chars-long
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
