# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://kiranawala_user:kiranawala_dev_2026@localhost:5432/kiranawala_dev

# ─── JWT (Day 2) ─────────────────────────────────────────
# Generate a secure random string:
#   Windows PowerShell:  [Convert]::ToBase64String((1..64 | % {Get-Random -Max 256}))
#   Mac/Linux:           openssl rand -base64 64
# MUST be at least 32 characters.
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64_to_generate_a_real_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────
# Exact origin, NOT a wildcard — wildcard breaks credentialed cookies.
CORS_ORIGIN=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
